{
  "name": "@dev-all/database",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "dependencies": {
    "tslib": "^2.3.0"
  },
  "nx": {
    "targets": {
      "studio": {
        "command": "npx prisma studio --config ./prisma.config.ts",
        "options": {
          "cwd": "packages/database"
        }
      },
      "migrate": {
        "command": "npx prisma migrate dev --config ./prisma.config.ts",
        "options": {
          "cwd": "packages/database"
        }
      },
      "generate": {
        "command": "npx prisma generate --config ./prisma.config.ts",
        "options": {
          "cwd": "packages/database"
        }
      }
    }
  }
}
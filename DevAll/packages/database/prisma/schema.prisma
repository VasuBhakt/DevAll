generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum CP_Platform {
  CODEFORCES
  CODECHEF
  LEETCODE
  ATCODER
}

enum Project_Platform {
  GITHUB
  GITLAB
  HUGGING_FACE
}

// User Model
model User {
  id                   String    @id @default(uuid())
  email                String    @unique
  username             String    @unique
  password             String
  role                 Role      @default(USER)
  verification_token   String?
  is_verified          Boolean   @default(false)
  verify_token_expiry  DateTime?
  refresh_token        String?
  forgot_password_token String?
  forgot_password_token_expiry DateTime?
  
  profile              Profile?
  cp_profiles          CP_Profile[]
  project_profiles     Project_Profile[]
  projects             Project[]
  achievements         Achievement[]

  created_at           DateTime  @default(now())
  updated_at           DateTime  @updatedAt
}

// Profile Model
model Profile {
  id                String  @id @default(uuid())
  user_id           String  @unique
  user              User    @relation(fields: [user_id], references: [id])
  
  name              String
  bio               String?
  profile_picture   String?
  institute         String?
  organization      String?
  readme            String?
  city              String?
  country           String?
  portfolio_website String?
  linkedin          String?
  github            String?
  xtwitter          String?
  instagram         String?
  reddit            String?
  twitch            String?
  youtube           String?
  discord           String?
  
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt
}

// CP Profile Model
model CP_Profile {
  user_id         String
  user            User        @relation(fields: [user_id], references: [id])
  platform        CP_Platform
  profile_link    String
  rating          Int?
  max_rating      Int?
  hard_problems   Int?
  medium_problems Int?
  easy_problems   Int?
  problems_solved Int?
  badge           String?
  contests        Json?
  
  created_at      DateTime    @default(now())
  updated_at      DateTime    @updatedAt

  @@id([user_id, platform])
}

// Project Profile Model
model Project_Profile {
  user_id         String
  user            User             @relation(fields: [user_id], references: [id])
  platform        Project_Platform
  profile_link    String
  followers_count Int?
  organizations   String[]
  pinned_repos    Json?
  models          Json?
  spaces          Json?
  datasets        Json?
  
  created_at      DateTime         @default(now())
  updated_at      DateTime         @updatedAt

  @@id([user_id, platform])
}

// Project Model
model Project {
  id           String   @id @default(uuid())
  user_id      String
  user         User     @relation(fields: [user_id], references: [id])
  name         String
  description  String
  tech_stack   String[]
  domains      String[]
  languages    String[]
  github_link  String?
  project_link String?
  
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt
}

// Achievement Model
model Achievement {
  id               String  @id @default(uuid())
  user_id          String
  user             User    @relation(fields: [user_id], references: [id])
  title            String
  description      String?
  certificate_link String?
  organization     String?
  event            String?
  event_link       String?
  
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt
}